{
  "google": {
    "client_secret_file": "client_secret.json",
    "token_file": "token.json",
    "album_cache_file": "album_cache.json"
  },
  "paths": {
    "inbox_dir": "inbox",
    "processed_dir": "processed"
  },
  "classification": {
